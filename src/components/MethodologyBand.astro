---
import type { Snapshot } from "../lib/snapshot/types";

interface Props {
  sources?: Snapshot["sources"];
  securityIntegrationsPending?: boolean;
}

const { sources = [], securityIntegrationsPending = false } = Astro.props as Props;
const staleSources = sources.filter((source) => source.status === "stale");
const staleSummary =
  staleSources.length > 0
    ? `${staleSources.length} source${staleSources.length === 1 ? "" : "s"} currently carried forward`
    : "All source feeds refreshed successfully in the latest publish";
const sourceSummary = securityIntegrationsPending
  ? "HaloPSA is live today. Security integrations are in progress and will be published once validated."
  : "HaloPSA, Qualys, and Datto RMM are aggregated into a single normalized snapshot.";
---
<section class="methodology">
  <div class="section-heading">
    <div>
      <h2>How we measure ourselves</h2>
      <p>Simple, accountable metrics refreshed daily across service and security.</p>
    </div>
  </div>
  <p class="freshness-callout">{staleSummary}</p>
  <ul>
    <li><strong>Sources:</strong> {sourceSummary}</li>
    <li><strong>Cadence:</strong> Daily publish with stale-source carry-forward to avoid zeroing trusted baselines.</li>
    <li><strong>Transparency:</strong> Metrics are published as collected from source systems, with stale-source markers when a feed is unavailable.</li>
  </ul>
</section>

<style>
  .freshness-callout {
    margin: 0 0 14px;
    color: rgba(20, 32, 51, 0.72);
    font-weight: 600;
  }
</style>
