---
type Status = 'current' | 'stale';

interface Props {
  name: string;
  status: Status;
  lastSuccessfulRefresh?: string;
  note?: string;
}

const { name, status, lastSuccessfulRefresh, note } = Astro.props as Props;

const statusLabel = status === 'current' ? 'Current' : 'Stale';
const statusClass = status === 'current' ? 'pill-accent' : '';
const formattedDate =
  lastSuccessfulRefresh &&
  new Intl.DateTimeFormat('en-GB', {
    timeZone: 'UTC',
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  }).format(new Date(lastSuccessfulRefresh));
---
<div class={`meta-pill ${statusClass}`}>
  <strong>{name}</strong>
  <span>• {statusLabel}</span>
  {formattedDate && <span>• Last successful update {formattedDate}</span>}
  {note && <span>• {note}</span>}
</div>
