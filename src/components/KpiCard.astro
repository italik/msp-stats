---
type Direction = 'up' | 'down' | 'flat' | undefined;

interface Props {
  label: string;
  value: string | number;
  context: string;
  direction?: Direction;
}

const { label, value, context, direction } = Astro.props as Props;

const arrow = {
  up: '▲',
  down: '▼',
  flat: '■'
}[direction ?? 'flat'];
---
<article class="kpi-card">
  <p class="kpi-label">{label}</p>
  <p class="kpi-value">{value}</p>
  <p class="kpi-context">{context}</p>
  {direction && <span class={`direction ${direction}`}>{arrow} {direction}</span>}
</article>
