---
import {
  formatAsOf,
  formatTrendDelta,
  formatTrendValue,
  summarizeTrendPoints,
  type TrendDisplayMode
} from "../lib/snapshot/formatters";

interface TrendPoint {
  date: string;
  value: number;
}

interface Props {
  label: string;
  points: TrendPoint[];
  eyebrow?: string;
  displayMode: TrendDisplayMode;
}

function toStableSlug(value: string): string {
  const slug = value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

  return slug || "trend";
}

function buildSparklineInstanceId(label: string, eyebrow: string, points: TrendPoint[]): string {
  const firstPointDate = points[0]?.date ?? "no-points";
  const lastPointDate = points[points.length - 1]?.date ?? "no-points";

  return `sparkline-${toStableSlug(label)}-${toStableSlug(eyebrow)}-${toStableSlug(firstPointDate)}-${toStableSlug(lastPointDate)}-${points.length}`;
}

const { label, points, eyebrow = "Up to 30 published days", displayMode } = Astro.props as Props;
const hasPoints = points?.length > 0;

if (!displayMode) {
  throw new Error(`Sparkline requires displayMode`);
}

const resolvedDisplayMode: TrendDisplayMode = displayMode;
const trendSummary = hasPoints ? summarizeTrendPoints(points) : null;
const sparklineInstanceId = buildSparklineInstanceId(label, eyebrow, points);
const sparklineDataId = `${sparklineInstanceId}-data`;

const values = hasPoints ? points.map((p) => p.value) : [];
const min = hasPoints ? Math.min(...values) : 0;
const max = hasPoints ? Math.max(...values) : 0;
const range = max - min || 1;

const chartPoints = hasPoints
  ? points.map((point, idx) => {
      const x = points.length === 1 ? 50 : (idx / (points.length - 1)) * 100;
      const y = 40 - ((point.value - min) / range) * 40;
      const pointDateLabel = formatAsOf(point.date);
      const pointValueLabel = formatTrendValue(point.value, resolvedDisplayMode);

      return {
        ...point,
        x,
        y,
        pointDateLabel,
        pointValueLabel,
        tooltipId: `${sparklineInstanceId}-point-${toStableSlug(point.date)}-${idx}`
      };
    })
  : [];

const polylinePoints = hasPoints ? chartPoints.map((point) => `${point.x},${point.y}`).join(" ") : "";
---
<article class="sparkline-card">
  <div class="sparkline-heading">
    <p class="sparkline-eyebrow">{eyebrow}</p>
    <p class="sparkline-title">{label}</p>
  </div>
  {hasPoints ? (
    <>
      <div class="sparkline-plot">
        <svg
          class="sparkline-chart"
          viewBox="0 0 100 40"
          role="img"
          aria-label={`${label} trend over ${eyebrow.toLowerCase()}`}
          aria-describedby={sparklineDataId}
        >
          <polyline points={polylinePoints} />
        </svg>
        <div class="sparkline-marker-layer" aria-hidden="true">
          {chartPoints.map((point, idx) => {
            const pointY = (point.y / 40) * 100;
            return (
              <span
                class="sparkline-marker"
                style={`--sparkline-x: ${point.x}%; --sparkline-y: ${pointY}%;`}
                data-trend-point-date={point.date}
                data-trend-point-value={point.value}
              >
                <svg class="sparkline-point-icon" viewBox="0 0 8 8" aria-hidden="true">
                  <circle cx="4" cy="4" r="3" />
                </svg>
                <span class="sparkline-tooltip-shell" id={point.tooltipId} role="tooltip">
                  <span class="sparkline-tooltip-date">{point.pointDateLabel}</span>
                  <span class="sparkline-tooltip-value">{point.pointValueLabel}</span>
                </span>
              </span>
            );
          })}
        </div>
      </div>
      <ul class="sparkline-point-list" id={sparklineDataId}>
        {chartPoints.map((point) => (
          <li>{`${point.pointDateLabel}: ${point.pointValueLabel}`}</li>
        ))}
      </ul>
      {trendSummary && (
        <dl class="sparkline-summary">
          <div>
            <dt>Latest</dt>
            <dd>{formatTrendValue(trendSummary.latest, resolvedDisplayMode)}</dd>
          </div>
          <div>
            <dt>Change</dt>
            <dd>{formatTrendDelta(trendSummary.delta, resolvedDisplayMode)}</dd>
          </div>
          <div>
            <dt>High</dt>
            <dd>{formatTrendValue(trendSummary.high, resolvedDisplayMode)}</dd>
          </div>
          <div>
            <dt>Low</dt>
            <dd>{formatTrendValue(trendSummary.low, resolvedDisplayMode)}</dd>
          </div>
        </dl>
      )}
    </>
  ) : (
    <p class="sparkline-empty">No trend data yet</p>
  )}
</article>

<style>
  .sparkline-card {
    background: var(--color-panel);
    border: 1px solid rgba(20, 32, 51, 0.08);
    border-radius: var(--radius-m);
    padding: 18px 18px 16px;
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sparkline-heading {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sparkline-eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: rgba(20, 32, 51, 0.55);
    font-size: 0.8rem;
  }

  .sparkline-title {
    margin: 0;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .sparkline-plot {
    position: relative;
  }

  .sparkline-chart {
    width: 100%;
    height: auto;
  }

  .sparkline-chart polyline {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 2;
  }

  .sparkline-marker-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .sparkline-marker {
    position: absolute;
    left: var(--sparkline-x);
    top: var(--sparkline-y);
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: inherit;
    cursor: pointer;
    pointer-events: auto;
  }

  .sparkline-point-icon {
    width: 10px;
    height: 10px;
    overflow: visible;
  }

  .sparkline-point-icon circle {
    fill: #fff;
    stroke: var(--color-accent);
    stroke-width: 1.6;
    transition: transform 0.14s ease, fill 0.14s ease, stroke-width 0.14s ease;
    transform-box: fill-box;
    transform-origin: center;
  }

  .sparkline-marker:hover .sparkline-point-icon circle {
    fill: var(--color-accent);
    stroke-width: 1.2;
    transform: scale(1.15);
  }

  .sparkline-tooltip-shell {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    min-width: max-content;
    padding: 8px 10px;
    border-radius: 10px;
    background: rgba(20, 32, 51, 0.96);
    color: #fff;
    box-shadow: 0 12px 24px rgba(20, 32, 51, 0.18);
    display: grid;
    gap: 2px;
    text-align: center;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(-50%) translateY(4px);
    transition: opacity 0.14s ease, transform 0.14s ease;
    pointer-events: none;
  }

  .sparkline-marker:hover .sparkline-tooltip-shell {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .sparkline-point-list {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .sparkline-tooltip-date {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.72);
  }

  .sparkline-tooltip-value {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .sparkline-summary {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
  }

  .sparkline-summary div {
    min-width: 0;
  }

  .sparkline-summary dt {
    margin: 0 0 2px;
    font-size: 0.74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(20, 32, 51, 0.55);
  }

  .sparkline-summary dd {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: rgba(20, 32, 51, 0.88);
  }

  .sparkline-empty {
    margin: 0;
    color: rgba(20, 32, 51, 0.55);
    font-style: italic;
  }

  @media (max-width: 520px) {
    .sparkline-summary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
