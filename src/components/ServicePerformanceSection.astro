---
import SectionHeading from "./SectionHeading.astro";
import KpiCard from "./KpiCard.astro";
import Sparkline from "./Sparkline.astro";
import type { Snapshot } from "../lib/snapshot/types";
import { formatAsOf, resolveSourceFreshness } from "../lib/snapshot/formatters";

interface Props {
  snapshot: Snapshot;
}

const { snapshot } = Astro.props as Props;

const metrics = snapshot.service.metrics;
const haloFreshness = resolveSourceFreshness(snapshot.sources, "HaloPSA", snapshot.overall.lastUpdated);

const slaTrend = snapshot.service.trends.slaAttainment ?? [];
const openedTrend = snapshot.service.trends.ticketsOpened ?? [];
const resolvedTrend = snapshot.service.trends.ticketsResolved ?? [];
const hasTrends = slaTrend.length > 0 || openedTrend.length > 0 || resolvedTrend.length > 0;
---
<section class="section-shell">
  <SectionHeading title="Service Performance" intro="Availability, response, and experience signals." />
  <div class="section-meta">
    <span class="meta-pill">Data current as of {formatAsOf(haloFreshness)}</span>
  </div>
  <div class="kpi-grid">
    {metrics.map((metric) => (
      <KpiCard
        label={metric.label}
        value={metric.value}
        context={metric.context}
        direction={metric.direction}
      />
    ))}
  </div>
  <div class="trend-block">
    <p class="trend-title">Recent trend</p>
    <p class="trend-note">
      Tickets opened and tickets resolved show yesterday's service activity. SLA attainment shows
      the rolling 30-day result captured on each publish day.
    </p>
    <div class="sparkline-grid">
      {slaTrend.length ? (
        <Sparkline label="SLA attainment" points={slaTrend} displayMode="percent" />
      ) : null}
      {openedTrend.length ? (
        <Sparkline label="Tickets opened" points={openedTrend} displayMode="count" />
      ) : null}
      {resolvedTrend.length ? (
        <Sparkline label="Tickets resolved" points={resolvedTrend} displayMode="count" />
      ) : null}
      {!hasTrends && <p class="trend-placeholder">Trend data will appear once service history is available.</p>}
    </div>
  </div>
</section>

<style>
  .section-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .trend-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .trend-title {
    margin: 0;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: rgba(20, 32, 51, 0.85);
  }

  .sparkline-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }

  .trend-note {
    margin: 0;
    color: rgba(20, 32, 51, 0.68);
  }

  .trend-placeholder {
    margin: 0;
    color: rgba(20, 32, 51, 0.6);
    font-style: italic;
  }
</style>
