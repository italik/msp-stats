---
import BaseLayout from '../layouts/BaseLayout.astro';
import SummaryHero from '../components/SummaryHero.astro';
import MethodologyBand from '../components/MethodologyBand.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SourceStatusPill from '../components/SourceStatusPill.astro';
import ServicePerformanceSection from '../components/ServicePerformanceSection.astro';
import SecurityPostureSection from '../components/SecurityPostureSection.astro';
import TrustFooter from '../components/TrustFooter.astro';
import { readSnapshot } from '../lib/snapshot/readSnapshot';

const title = import.meta.env.PUBLIC_SITE_TITLE ?? 'Italik Trust Report';
const snapshot = await readSnapshot('data/snapshots/latest.json');
const isFixtureBacked = (note?: string) => /fixture payload|integration pending/i.test(note ?? '');
const publicSources = snapshot.sources.filter((source) => !isFixtureBacked(source.note));
const hasLiveSecurity = ['Qualys', 'Datto RMM'].every((name) =>
  publicSources.some((source) => source.name === name)
);
const securityIntegrationsPending = !hasLiveSecurity;
const liveSummaryKpiIds = new Set(['tickets-handled', 'sla-attainment', 'ticket-volume']);
const summaryKpis = hasLiveSecurity
  ? snapshot.summary.kpis
  : snapshot.summary.kpis.filter((kpi) => liveSummaryKpiIds.has(kpi.id));
---
<BaseLayout {title}>
  <SummaryHero snapshot={snapshot} kpis={summaryKpis} />

  <MethodologyBand
    sources={publicSources}
    securityIntegrationsPending={securityIntegrationsPending}
  />

  <ServicePerformanceSection snapshot={snapshot} />

  {hasLiveSecurity ? <SecurityPostureSection snapshot={snapshot} /> : null}

  <section class="section-shell">
    <SectionHeading
      title="Live source status"
      intro="Current/stale state and last successful update across published data sources."
    />
    <div class="hero-meta">
      {publicSources.map((source) => (
        <SourceStatusPill
          name={source.name}
          status={source.status}
          lastSuccessfulRefresh={source.lastSuccessfulRefresh}
          note={source.note}
        />
      ))}
    </div>
  </section>

  <TrustFooter securityIntegrationsPending={securityIntegrationsPending} />
</BaseLayout>
