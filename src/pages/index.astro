---
const title = import.meta.env.PUBLIC_SITE_TITLE ?? 'MSP Trust Dashboard';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <header>
        <h1>{title}</h1>
        <p>Modern trust signals for IT service providers.</p>
      </header>
      <section>
        <h2>Italik</h2>
        <p>Service ownership pillars and measurement framing.</p>
      </section>
      <section>
        <h2>Service Performance</h2>
        <p>Latency and reliability roll-ups across shared services.</p>
      </section>
      <section>
        <h2>Security Posture</h2>
        <p>Compliance readiness and attack surface health.</p>
      </section>
    </main>
  </body>
</html>
