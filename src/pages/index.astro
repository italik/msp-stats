---
import BaseLayout from '../layouts/BaseLayout.astro';
import SummaryHero from '../components/SummaryHero.astro';
import MethodologyBand from '../components/MethodologyBand.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SourceStatusPill from '../components/SourceStatusPill.astro';
import ServicePerformanceSection from '../components/ServicePerformanceSection.astro';
import SecurityPostureSection from '../components/SecurityPostureSection.astro';
import TrustFooter from '../components/TrustFooter.astro';
import { readSnapshot } from '../lib/snapshot/readSnapshot';

const title = import.meta.env.PUBLIC_SITE_TITLE ?? 'Italik Trust Report';
const snapshot = await readSnapshot('data/snapshots/latest.json');
---
<BaseLayout {title}>
  <SummaryHero snapshot={snapshot} />

  <MethodologyBand />

  <ServicePerformanceSection snapshot={snapshot} />

  <SecurityPostureSection snapshot={snapshot} />

  <section class="section-shell">
    <SectionHeading
      title="Source status"
      intro="Current/stale state and last successful update across each data source."
    />
    <div class="hero-meta">
      {snapshot.sources.map((source) => (
        <SourceStatusPill
          name={source.name}
          status={source.status}
          lastSuccessfulRefresh={source.lastSuccessfulRefresh}
          note={source.note}
        />
      ))}
    </div>
  </section>

  <TrustFooter />
</BaseLayout>
