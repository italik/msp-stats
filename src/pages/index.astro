---
import BaseLayout from '../layouts/BaseLayout.astro';
import SummaryHero from '../components/SummaryHero.astro';
import MethodologyBand from '../components/MethodologyBand.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SourceStatusPill from '../components/SourceStatusPill.astro';
import { readSnapshot } from '../lib/snapshot/readSnapshot';

const title = import.meta.env.PUBLIC_SITE_TITLE ?? 'Italik Trust Report';
const snapshot = await readSnapshot('data/snapshots/latest.json');
---
---
<BaseLayout {title}>
  <SummaryHero snapshot={snapshot} />

  <MethodologyBand />

  <section class="section-shell">
    <SectionHeading title="Service Performance" intro="Availability, response, and experience signals." />
    <div class="meta-pill">Operational detail coming next</div>
  </section>

  <section class="section-shell">
    <SectionHeading title="Security Posture" intro="Detection, remediation, and coverage across the fleet." />
    <div class="meta-pill">Security detail coming next</div>
  </section>

  <section class="section-shell">
    <SectionHeading title="Source status" intro="Latest refresh across each data source." />
    <div class="hero-meta">
      {snapshot.sources.map((source) => (
        <SourceStatusPill
          name={source.name}
          status={source.status}
          lastSuccessfulRefresh={source.lastSuccessfulRefresh}
          note={source.note}
        />
      ))}
    </div>
  </section>
</BaseLayout>
